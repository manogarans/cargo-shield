<!DOCTYPE html>

<html>

<head>

<title>Cargo Security Dashboard</title>

<script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-app.js"></script>

<script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-database.js"></script>

<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css"/>

<style>

body{
margin:0;
display:flex;
height:100vh;
font-family:Arial;
}

/* BIG MAP */

#map{
width:80%;
height:100%;
}

/* RIGHT PANEL */

#panel{
width:20%;
background:#020617;
color:white;
padding:20px;
}

#door{
    width:180px;
    height:60px;
    background:red;
    color:white;
    font-weight:bold;
    font-size:22px;
    display:flex;
    align-items:center;
    justify-content:center;
    margin-top:20px;
    border-radius:8px;
    }

@keyframes blink{
0%{opacity:1;}
50%{opacity:0.2;}
100%{opacity:1;}
}

</style>

</head>

<body>

<div id="map"></div>

<div id="panel">

<h2>Truck Security</h2>

<h3>Door Status</h3>
<div id="door">OPEN</div>

<h3>Latitude</h3>
<p id="lat">Loading...</p>

<h3>Longitude</h3>
<p id="lon">Loading...</p>

<h3>Stop Alert</h3>
<p id="stop">Truck Moving</p>

</div>

<script>

var firebaseConfig = {
databaseURL:"https://cargo-security-default-rtdb.firebaseio.com/"
};

firebase.initializeApp(firebaseConfig);

/* DATABASE PATH */

var db = firebase.database().ref("truck_01");

</script>

<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

<script>

/* CREATE MAP */

var map = L.map('map').setView([13.0827,80.2707],7);

L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

var truckIcon = L.icon({
    iconUrl: 'truck.png',
    iconSize: [40,40],
    iconAnchor: [20,20]
});

var marker = L.marker([13.0827,80.2707], {icon: truckIcon}).addTo(map);

/* READ FIREBASE */

db.on("value", function(snapshot){

var data = snapshot.val();

if(data){

var lat = parseFloat(data.latitude);
var lon = parseFloat(data.longitude);

/* UPDATE MAP */

marker.setLatLng([lat,lon]);
map.setView([lat,lon],14);

/* SHOW LAT LON */

document.getElementById("lat").innerHTML = lat;
document.getElementById("lon").innerHTML = lon;

/* DOOR STATUS */
var door = document.getElementById("door");

if(data.door=="closed"){

door.style.background="green";
door.innerHTML="CLOSED";

}
else{

door.style.background="red";
door.innerHTML="OPEN";

}

/* STOP ALERT */

if(data.stop_time>30){
document.getElementById("stop").innerHTML=
"Truck stopped at "+lat+" , "+lon;
}

}

});

</script>

</body>
</html>
